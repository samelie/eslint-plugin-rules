{
  "name": "@adddog/eslint-plugin-rules",
  "type": "module",
  "version": "0.0.17",
  "private": false,
  "homepage": "https://github.com/samelie/eslint-plugin-rules#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/samelie/eslint-plugin-rules.git"
  },
  "bugs": {
    "url": "https://github.com/samelie/eslint-plugin-rules/issues"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">= 22",
    "pnpm": ">= 10",
    "npm": ">= 11"
  },
  "scripts": {
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "types": "tsc -p tsconfig.typecheck.json",
    "test": "vitest --watch=false",
    "prepare": "unbuild",
    "release": "bumpp --yes --no-push --no-tag --release patch",
    "dev": "tsx src/index.ts",
    "knip": "knip",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "peerDependencies": {
    "knip": "^5.64.3",
    "typescript": "^5.9.3",
    "vitest": ">=3.2.4"
  },
  "devDependencies": {
    "@adddog/monorepo-consistency": "workspace:*",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/rule-tester": "^8.58.2",
    "@typescript-eslint/utils": "^8.58.2",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
